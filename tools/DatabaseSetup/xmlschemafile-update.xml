<?xml version="1.0"?>
<schema version="0.3">
    <table name="xml_schema_test">
        <opt platform="mysql">ENGINE=INNODB</opt>
        <descr>A test table for xmlschema unit testing</descr>
            <descr>A unique ID assigned to each record.</descr>
        <field name="id" type="I">
            <KEY/>
            <AUTOINCREMENT/>
        </field> 
        <descr>Varchar_field increases the size to 280 characters</descr>
        <field name="varchar_field" type="C" size="280">
            <NOTNULL/>
            <DEFAULT VALUE="this is a default value"/>
        </field>
        <field name="nvarchar_field" type="C2" size="240"><NOTNULL/></field>

        <field name="varchar_field_for_default" type="C" size="100">
            <DEFAULT VALUE="this is a no-change default value"/>
        </field>
        <field name="varchar_field_to_add" type="C" size="280"><NOTNULL/><default value="TEST"/></field>
        <field name="decimal_field" type="N" size="12.4">
            <default value="1"/>
        </field>
        <field name="decimal_field_change" type="N" size="14.8">
            <default value="801.11"/>
        </field>
        <field name="integer_field" type="I8">
            <default value="999"/>
        </field>
        <field name="integer_field_to_grow" type="I4"/>
        <field name="logical_field" type="L">
            <default value="0"/>
        </field>
        <field name="blob_field" type="B"></field>
        <field name="xl_field" type="XL"></field>
        <field name="date_field_to_add" type="D"><DEFDATE/></field>
        <field name="date_field_to_keep" type="D"><DEFDATE/><comment>MODIFIED DATE FIELD COMMENT</comment></field>
        <field name="date_hard_default_change" type="D">
            <default value='2027-01-01'/>
        </field>
        <field name="timestamp_field_to_add" type="T"><DEFTIMESTAMP/><comment>TIMESTAMP FIELD COMMENT</comment></field>
        <field name="timestamp_field_to_keep" type="T"><DEFTIMESTAMP/></field>
        <field name="unsigned_integer_field" type="I4">
            <UNSIGNED/>
            <NOTNULL/>
            <default VALUE="0"/>
        </field>

        <index name="integer_field_index">
            <descr>Put a unique index on the integer_field</descr> 
            <col>integer_field</col>
            <UNIQUE/>
        </index>
    </table>
</schema>	