<?xml version="1.0"?>
<schema version="0.3">
    <table name="xml_schema_test">
        <opt platform="mysql">ENGINE=INNODB</opt>
        
        <descr>A test table for xmlschema unit testing</descr>
        <comment>XML SCHEMA COMMENT</comment> 
        <field name="id" type="I">
            <descr>A unique ID assigned to each record.</descr>
            <KEY/>
            <AUTOINCREMENT/>
        </field> 
        <field name="varchar_field" type="C" size="240"><NOTNULL/></field>
        <field name="nvarchar_field" type="C2" size="120"><NOTNULL/></field>
        <field name="varchar_field_to_drop" type="C" size="240">
            <DEFAULT VALUE="this is not a default value"/>
        </field>
        <field name="varchar_field_for_default" type="C" size="100">
            <DEFAULT VALUE="this is a no-change default value"/>
        </field>
        <field name="decimal_field" type="N" size="12.4">
            <default value="1"/>
        </field>
        <field name="decimal_field_change" type="N" size="12.2"/>
        <field name="integer_field" type="I4">
            <default value="999"/>
        </field>
        <field name="integer_field_to_grow" type="I2"></field>
        <field name="logical_field" type="L">
            <default value="1"/>
        </field>
        <field name="blob_field" type="B"></field>
        <field name="xl_field" type="XL"></field>
        <field name="date_hard_default_field" type="D">
            <DEFAULT VALUE='2025-01-01'/>
        </field>
        <field name="date_field" type="D"><DEFDATE/></field>
        <field name="date_field_to_keep" type="D"><DEFDATE/><comment>DATE FIELD COMMENT</comment></field>
        <field name="date_hard_default_change" type="D">
            <default value='2026-01-01'/>
        </field>
        <field name="timestamp_field" type="T"><DEFTIMESTAMP/></field>
        <field name="timestamp_field_to_keep" type="T"><DEFTIMESTAMP/></field>
       
    
        <index name="integer_field_index">
            <descr>Put a unique index on the integer_field</descr>
            <col>integer_field</col>
            <UNIQUE/>
        </index>
        <index name="droppable_index">
            <descr>Adds an index to apply a drop to</descr>
            <comment>DROPPABLE INDEX COMMENT</comment>
            <col>nvarchar_field</col>
            <UNIQUE/>
        </index>
    </table>
    <sql>
        <descr>Insert a record into the table after creation</descr>
        <query>insert into xml_schema_test (varchar_field,nvarchar_field) values ( 'Test Record 1','Test Record 1')</query>
        <query>insert into xml_schema_test (varchar_field,nvarchar_field,decimal_field,integer_field) values ( 'Test Record 2','Test Record 2', 888,8.0111 )</query>
    </sql>
</schema>	